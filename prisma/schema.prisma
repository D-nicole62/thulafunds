generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id              String    @id @default(uuid())
  full_name       String?
  avatar_url      String?
  bio             String?   @db.Text
  wallet_address  String?
  wallet_type     String?
  wallet_verified Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now())
  campaigns       Campaign[]
  donations       Donation[]

  @@map("profiles")
}

model Campaign {
  id                         String           @id @default(uuid())
  created_at                 DateTime         @default(now())
  updated_at                 DateTime         @default(now())
  title                      String
  description                String?          @db.Text
  current_amount             Decimal          @default(0) @db.Decimal(15, 2)
  on_chain_balance           Decimal          @default(0) @db.Decimal(15, 2)
  goal_amount                Decimal          @db.Decimal(15, 2)
  status                     String           @default("active")
  category                   String?
  image_url                  String?          @db.Text
  wallet_address             String?
  contract_address           String?
  milestone_contract_address String?
  payment_method             String?
  deadline                   DateTime?
  creator_id                 String
  creator                    Profile          @relation(fields: [creator_id], references: [id])
  donations                  Donation[]
  campaign_updates           CampaignUpdate[]
  milestones                 Milestone[]

  is_boosted       Boolean         @default(false)
  boost_type       String?
  boost_expires_at DateTime?
  boosts           CampaignBoost[]

  @@map("campaigns")
}

model CampaignUpdate {
  id          String   @id @default(uuid())
  created_at  DateTime @default(now())
  title       String
  content     String   @db.Text
  campaign_id String
  campaign    Campaign @relation(fields: [campaign_id], references: [id])

  @@map("campaign_updates")
}

model CampaignBoost {
  id             String   @id @default(uuid())
  campaign_id    String
  campaign       Campaign @relation(fields: [campaign_id], references: [id])
  boost_type     String
  duration_hours Int
  status         String
  payment_proof  String
  created_at     DateTime @default(now())
  expires_at     DateTime

  @@map("campaign_boosts")
}

/// On-chain donations — every financial action stores a Stellar tx hash
model Donation {
  id             String   @id @default(uuid())
  created_at     DateTime @default(now())
  amount         Decimal  @db.Decimal(15, 2)
  message        String?  @db.Text
  anonymous      Boolean  @default(false)
  tx_hash        String   @unique
  campaign_id    String
  campaign       Campaign @relation(fields: [campaign_id], references: [id])
  contributor_id String
  contributor    Profile  @relation(fields: [contributor_id], references: [id])

  @@map("donations")
}

model Milestone {
  id              String    @id @default(uuid())
  created_at      DateTime  @default(now())
  title           String
  amount          Decimal   @db.Decimal(15, 2)
  status          String    @default("pending")
  release_tx_hash String?
  released_at     DateTime?
  sort_order      Int       @default(0)
  campaign_id     String
  campaign        Campaign  @relation(fields: [campaign_id], references: [id])

  @@map("milestones")
}

model PaymentSession {
  id           String   @id @default(uuid())
  created_at   DateTime @default(now())
  tx_hash      String   @unique
  endpoint     String
  status       String
  amount       Decimal  @db.Decimal(15, 2)
  from_address String?

  @@map("payment_sessions")
}
